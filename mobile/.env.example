# A physical device can't reach "localhost" — use the machine's LAN IP instead
# (e.g. http://192.168.1.23:8080).
EXPO_PUBLIC_API_URL=http://localhost:8080

# Real Privy Expo embedded wallet path (dashboard > mobile client). Leave unset
# to use the SecureStore demo wallet — that's the default and the shipped cut.
# Requires a dev-client build (`npx expo prebuild && npx expo run:ios`); does
# not run in Expo Go.
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Apple Team ID — required only for signed device builds of the widget extension
EXPO_APPLE_TEAM_ID=

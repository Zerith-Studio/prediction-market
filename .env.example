# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Required — Postgres (Neon works; the URL includes credentials)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# HTTP listen address
PITCHMARKET_ADDR=:8080

# On-chain settlement (leave unset to run fills off-chain-mirror only)
#SOLANA_RPC_URL=https://api.devnet.solana.com
#OPERATOR_KEYPAIR=/path/to/operator-keypair.json
#PROGRAM_ID=3fdgRPcZnwWcaGi197dkZDyq24VHoWJcGzKTVfMxNPWs
#USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Feed: replay (recorded fixtures, default) or txodds (live)
FEED_PROVIDER=replay
REPLAY_DIR=fixtures
REPLAY_SPEED=60
#TXODDS_URL=
#TXODDS_API_KEY=

# Demo: auto-register this fixture and stream it at boot
#DEMO_FIXTURE=demo-final
#DEMO_HOME=Argentina
#DEMO_AWAY=France

# Market maker bot (set to "off" to disable)
MM_BOT=on

# One-liner ticker (optional; feature off without a key)
#ANTHROPIC_API_KEY=

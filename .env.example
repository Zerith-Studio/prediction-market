# Copy to .env (backend) — gitignored, never commit secrets.

# Required — Postgres (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ON-CHAIN mode (recommended): markets on devnet, crank settles, real deposits
SOLANA_RPC_URL=https://api.devnet.solana.com
OPERATOR_KEYPAIR=~/.config/solana/id.json
#USDC_MINT=            # auto-created + cached to .pitchmarket-usdc when unset
#PROGRAM_ID=3fdgRPcZnwWcaGi197dkZDyq24VHoWJcGzKTVfMxNPWs

# Feed — TxLINE live (default in on-chain mode). Credentials self-provision
# via the free World Cup tier (guest JWT + on-chain subscribe) and cache to
# TXODDS_CACHE. FEED_PROVIDER=replay + DEMO_FIXTURE for the recorded fallback.
#FEED_PROVIDER=txodds
#TXODDS_URL=https://txline-dev.txodds.com
#TXODDS_COMPETITION=72   # World Cup
#TXODDS_CACHE=.txline-credentials.json

# One-liners (optional): Gemini preferred, Claude fallback
#GEMINI_API_KEY=
#GEMINI_MODEL=gemini-3.0-flash
#ANTHROPIC_API_KEY=

# Admin panel (/admin): the base58 pubkey allowed to administer — set it to the
# wallet you'll sign with IN THE BROWSER (your Privy or local demo wallet), not
# a server keypair. Defaults to the operator's pubkey when unset in on-chain
# mode; leave blank with no operator to keep /admin disabled (503).
#ADMIN_PUBKEY=

MM_BOT=on
#CORS_ORIGIN=http://localhost:3000
PITCHMARKET_ADDR=:8080

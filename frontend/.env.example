# Copy to .env.local. Both are optional — the app runs on fixtures without them.

# Go backend origin. Set to go live (REST + /ws); unset = demo fixtures.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Privy app id → real embedded-wallet login (privy.io dashboard).
# Unset = local demo wallet (ed25519 key in localStorage) — still signs real
# orders against the real exchange; the backend can't tell the difference.
#NEXT_PUBLIC_PRIVY_APP_ID=
